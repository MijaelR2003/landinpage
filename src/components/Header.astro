---
// Header Component
---

<header class="sticky top-0 z-50 glass border-b border-gold-500/15 text-white shadow-lg shadow-navy-950/30">
  <!-- Thin gold accent line at top -->
  <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-gold-500 to-transparent"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      
      <!-- Logo / Brand with real logo image -->
      <a href="#inicio" class="flex items-center space-x-3 group">
        <!-- Real Logo Image -->
        <div class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-xl overflow-hidden border border-gold-500/30 shadow-md shadow-gold-500/10 group-hover:border-gold-400/60 transition-all duration-300">
          <img 
            src="/images/Logo.jpeg" 
            alt="Lambin Suite Logo" 
            class="w-full h-full object-cover"
            width="48"
            height="48"
          />
        </div>
        
        <!-- Text Logo following the logo image layout -->
        <div class="flex flex-col">
          <span class="text-[9px] sm:text-[10px] font-bold uppercase tracking-[0.25em] text-gold-400/90 leading-none">Hospedaje</span>
          <span class="font-brand font-bold text-base sm:text-lg tracking-wide text-white leading-tight mt-0.5 group-hover:text-gold-300 transition-colors duration-200">LAMBIN SUITE</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-8">
        <a href="#inicio" class="text-sm font-semibold text-navy-100 hover:text-gold-400 transition-colors duration-200 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-gold-500 after:transition-all after:duration-300 hover:after:w-full">Inicio</a>
        <a href="#habitaciones" class="text-sm font-semibold text-navy-100 hover:text-gold-400 transition-colors duration-200 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-gold-500 after:transition-all after:duration-300 hover:after:w-full">Habitaciones</a>
        <a href="#promociones" class="text-sm font-semibold text-navy-100 hover:text-gold-400 transition-colors duration-200 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-gold-500 after:transition-all after:duration-300 hover:after:w-full">Promociones</a>
        <a href="#ubicacion" class="text-sm font-semibold text-navy-100 hover:text-gold-400 transition-colors duration-200 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-gold-500 after:transition-all after:duration-300 hover:after:w-full">Ubicación</a>
        <a href="#contacto" class="text-sm font-semibold text-navy-100 hover:text-gold-400 transition-colors duration-200 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-gold-500 after:transition-all after:duration-300 hover:after:w-full">Contacto</a>
      </nav>

      <!-- Action Button (Desktop) -->
      <div class="hidden md:block">
        <a
          href="https://wa.me/59169954561?text=Hola%20Lambin%20Suite,%20me%20gustar%C3%ADa%20realizar%20una%20consulta%20para%20una%20reserva."
          target="_blank"
          rel="noopener noreferrer"
          class="shimmer-btn inline-flex items-center justify-center px-5 py-2.5 border border-transparent text-sm font-bold rounded-lg text-navy-950 bg-gradient-to-r from-gold-500 to-gold-400 hover:from-gold-400 hover:to-gold-300 shadow-lg shadow-gold-500/15 hover:shadow-gold-500/30 active:scale-95 transition-all duration-200"
        >
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          Reservar WhatsApp
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="flex items-center md:hidden">
        <button
          type="button"
          id="mobile-menu-button"
          class="inline-flex items-center justify-center p-2 rounded-lg text-navy-200 hover:text-gold-400 hover:bg-navy-800/50 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-gold-500 transition-all duration-200"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Abrir menú principal</span>
          <!-- Icon Menu (Closed state) -->
          <svg class="block h-6 w-6" id="menu-icon-closed" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <!-- Icon Close (Open state) -->
          <svg class="hidden h-6 w-6" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu, show/hide based on menu state. -->
  <div class="hidden md:hidden bg-navy-900/98 backdrop-blur-xl border-b border-gold-500/10" id="mobile-menu">
    <div class="px-4 pt-3 pb-4 space-y-1">
      <a href="#inicio" class="mobile-nav-link block px-4 py-3 rounded-xl text-base font-semibold text-navy-100 hover:text-gold-400 hover:bg-navy-800/50 transition-all">Inicio</a>
      <a href="#habitaciones" class="mobile-nav-link block px-4 py-3 rounded-xl text-base font-semibold text-navy-100 hover:text-gold-400 hover:bg-navy-800/50 transition-all">Habitaciones</a>
      <a href="#promociones" class="mobile-nav-link block px-4 py-3 rounded-xl text-base font-semibold text-navy-100 hover:text-gold-400 hover:bg-navy-800/50 transition-all">Promociones</a>
      <a href="#ubicacion" class="mobile-nav-link block px-4 py-3 rounded-xl text-base font-semibold text-navy-100 hover:text-gold-400 hover:bg-navy-800/50 transition-all">Ubicación</a>
      <a href="#contacto" class="mobile-nav-link block px-4 py-3 rounded-xl text-base font-semibold text-navy-100 hover:text-gold-400 hover:bg-navy-800/50 transition-all">Contacto</a>
    </div>
    <div class="pt-3 pb-5 px-4 border-t border-navy-800/60">
      <a
        href="https://wa.me/59169954561?text=Hola%20Lambin%20Suite,%20me%20gustar%C3%ADa%20realizar%20una%20consulta%20para%20una%20reserva."
        target="_blank"
        rel="noopener noreferrer"
        class="shimmer-btn flex items-center justify-center w-full px-5 py-3.5 border border-transparent text-base font-bold rounded-xl text-navy-950 bg-gradient-to-r from-gold-500 to-gold-400 hover:from-gold-400 hover:to-gold-300 active:scale-[0.98] transition-all duration-150 shadow-lg shadow-gold-500/20"
      >
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        Reservar por WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconClosed = document.getElementById('menu-icon-closed');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  if (mobileMenuButton && mobileMenu && menuIconClosed && menuIconOpen) {
    // Toggle menu visibility
    mobileMenuButton.addEventListener('click', () => {
      const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
      
      mobileMenuButton.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
      mobileMenu.classList.toggle('hidden');
      menuIconClosed.classList.toggle('hidden');
      menuIconOpen.classList.toggle('hidden');
    });

    // Close menu when a link is clicked
    mobileNavLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
        menuIconClosed.classList.remove('hidden');
        menuIconOpen.classList.add('hidden');
      });
    });
  }
</script>
