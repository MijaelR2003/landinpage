---
// Hero Component
---

<section id="inicio" class="relative bg-gradient-to-b from-navy-900 via-navy-950 to-navy-900 overflow-hidden pt-12 pb-20 sm:pt-16 sm:pb-28 lg:pt-24 lg:pb-36 flex items-center">
  <!-- Decorative background elements matching the logo tone -->
  <div class="absolute inset-0 opacity-40">
    <div class="absolute -top-40 -left-40 w-96 h-96 rounded-full bg-gold-600/10 blur-3xl"></div>
    <div class="absolute top-1/2 right-0 w-80 h-80 rounded-full bg-navy-500/20 blur-3xl"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Text content -->
      <div class="lg:col-span-7 flex flex-col justify-center text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center self-center lg:self-start px-4 py-1.5 rounded-full text-xs font-semibold bg-gold-500/10 text-gold-400 border border-gold-500/25 mb-6 uppercase tracking-wider">
          📍 A 3 minutos de la Terminal Bimodal
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-tight">
          Tu descanso al instante en <span class="font-brand text-transparent bg-clip-text bg-gradient-to-r from-gold-300 via-gold-400 to-gold-500">El Alto</span>
        </h1>
        
        <p class="mt-6 text-base sm:text-lg text-navy-100 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          Habitaciones cómodas, limpias y seguras. Ideal para viajeros en tránsito. Consulta precios y disponibilidad de inmediato sin esperas. Recepción las 24 horas.
        </p>
        
        <!-- Action Buttons -->
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
          <!-- WhatsApp Call to Action -->
          <a
            href="https://wa.me/59170000000?text=Hola%20Lambin%20Suite,%20me%20gustar%C3%ADa%20consultar%20por%20habitaciones%20disponibles%20para%20hoy."
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-bold rounded-xl text-navy-950 bg-gold-500 hover:bg-gold-400 hover:scale-[1.02] shadow-lg shadow-gold-500/20 hover:shadow-gold-500/35 transition-all duration-200"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Reservar por WhatsApp
          </a>
          <!-- Scroll to Rooms Button -->
          <a
            href="#habitaciones"
            class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 border border-navy-700 text-base font-bold rounded-xl text-white bg-navy-900/40 hover:bg-navy-900 hover:border-gold-500/50 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
          >
            Ver Habitaciones y Tarifas
          </a>
        </div>
        
        <!-- Key Highlights Grid -->
        <div class="mt-12 grid grid-cols-2 gap-4 border-t border-navy-800/80 pt-8 max-w-lg mx-auto lg:mx-0">
          <div class="flex items-center space-x-3 text-left">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-gold-500/10 flex items-center justify-center text-gold-400">
              ⚡
            </div>
            <span class="text-sm font-semibold text-navy-100">WiFi de Alta Velocidad</span>
          </div>
          <div class="flex items-center space-x-3 text-left">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-gold-500/10 flex items-center justify-center text-gold-400">
              🚿
            </div>
            <span class="text-sm font-semibold text-navy-100">Agua Caliente 24/7</span>
          </div>
          <div class="flex items-center space-x-3 text-left">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-gold-500/10 flex items-center justify-center text-gold-400">
              🔑
            </div>
            <span class="text-sm font-semibold text-navy-100">Recepción 24 Horas</span>
          </div>
          <div class="flex items-center space-x-3 text-left">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-gold-500/10 flex items-center justify-center text-gold-400">
              🔒
            </div>
            <span class="text-sm font-semibold text-navy-100">Seguridad Garantizada</span>
          </div>
        </div>
      </div>
      
      <!-- Hero Image -->
      <div class="lg:col-span-5 flex justify-center">
        <div class="relative w-full max-w-md lg:max-w-none">
          <!-- Image decorative frames -->
          <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-gold-500 to-gold-600 opacity-25 blur-lg"></div>
          <div class="relative bg-navy-950 rounded-2xl overflow-hidden shadow-2xl border border-navy-800">
            <img
              src="/images/hero.png"
              alt="Recepción de Lambin Suite"
              width="600"
              height="600"
              class="w-full h-auto object-cover aspect-square hover:scale-105 transition-transform duration-700"
              loading="eager"
            />
            <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-navy-950 via-navy-950/40 to-transparent p-6 text-left">
              <p class="font-brand text-gold-400 font-extrabold text-lg tracking-wide">Lambin Suite</p>
              <p class="text-navy-100 text-xs mt-1">Ambiente acogedor, limpio y familiar para tu estadía.</p>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>
