---
// ContactForm Component
---

<section id="contacto" class="py-20 bg-gradient-to-b from-white to-navy-50/50 relative">
  <!-- Subtle dot pattern -->
  <div class="absolute inset-0 bg-dot-pattern opacity-20"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-navy-900 tracking-tight">
        Reservas y Consultas
      </h2>
      <div class="h-1.5 w-20 bg-gradient-to-r from-gold-600 via-gold-400 to-gold-600 mx-auto mt-4 rounded-full"></div>
      <p class="mt-5 text-lg text-navy-700/80">
        Reserva tu habitación en un minuto. Completa el formulario de abajo para procesar tu solicitud mediante nuestro sistema o escríbenos directamente.
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">
      
      <!-- WhatsApp Alternative Info Block -->
      <div class="lg:col-span-5 flex flex-col justify-between bg-gradient-to-br from-navy-900 to-navy-950 text-white p-8 sm:p-10 rounded-2xl shadow-2xl shadow-navy-950/30 relative overflow-hidden border border-gold-500/10">
        <!-- Decorative elements -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/8 rounded-full blur-[60px]"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-navy-500/10 rounded-full blur-[50px]"></div>
        <!-- Dot pattern -->
        <div class="absolute inset-0 bg-dot-pattern opacity-15"></div>
        
        <div class="relative z-10">
          <h3 class="text-2xl font-bold text-white mb-6">¿Llegas pronto y tienes prisa?</h3>
          <p class="text-navy-200 text-sm sm:text-base leading-relaxed mb-8">
            Si estás a minutos de llegar o ya estás en la Terminal Bimodal, escribirnos por WhatsApp es la forma más rápida de asegurar tu habitación sin esperas.
          </p>
          
          <!-- Quick contact stats -->
          <div class="space-y-4 mb-8">
            <div class="flex items-center space-x-3">
              <div class="w-8 h-8 rounded-lg glass flex items-center justify-center">
                <span class="text-gold-400 text-lg">💬</span>
              </div>
              <span class="text-sm font-semibold text-navy-100">Respuesta en menos de 5 minutos</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-8 h-8 rounded-lg glass flex items-center justify-center">
                <span class="text-gold-400 text-lg">📞</span>
              </div>
              <span class="text-sm font-semibold text-navy-100">Llamadas directas habilitadas</span>
            </div>
          </div>
        </div>
        
        <!-- Big WhatsApp Button -->
        <div class="relative z-10">
          <a
            href="https://wa.me/59169954561?text=Hola%20Lambin%20Suite,%20estoy%20cerca%20de%20la%20Terminal%20y%20quisiera%20saber%20si%20tienen%20habitaci%C3%B3n%20disponible%20para%20ingreso%20inmediato."
            target="_blank"
            rel="noopener noreferrer"
            class="shimmer-btn flex items-center justify-center w-full px-6 py-4 border border-transparent text-base font-bold rounded-xl text-navy-950 bg-gradient-to-r from-gold-500 to-gold-400 hover:from-gold-400 hover:to-gold-300 active:scale-95 transition-all duration-150 shadow-lg shadow-gold-500/25"
          >
            <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Escribir por WhatsApp
          </a>
        </div>
      </div>
      
      <!-- Netlify Form Block -->
      <div class="lg:col-span-7 glass-light p-8 rounded-2xl shadow-lg">
        <h3 class="text-xl font-bold text-navy-900 mb-6">Formulario de Reserva</h3>
        
        <form 
          name="contacto" 
          method="POST" 
          data-netlify="true" 
          class="space-y-6"
          action="/gracias"
        >
          <!-- Netlify hidden form input -->
          <input type="hidden" name="form-name" value="contacto" />
          
          <!-- Name Field -->
          <div>
            <label for="nombre" class="block text-xs font-bold uppercase tracking-wider text-navy-400 mb-2 font-brand">Nombre Completo</label>
            <input 
              type="text" 
              name="nombre" 
              id="nombre" 
              required 
              placeholder="Ej. Juan Pérez" 
              class="w-full px-4 py-3.5 bg-white border border-navy-200/80 rounded-xl text-navy-900 text-sm focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:border-gold-500 transition-all shadow-sm"
            />
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Cellphone Field -->
            <div>
              <label for="celular" class="block text-xs font-bold uppercase tracking-wider text-navy-400 mb-2 font-brand">Número de Celular</label>
              <input 
                type="tel" 
                name="celular" 
                id="celular" 
                required 
                placeholder="Ej. 69954561" 
                class="w-full px-4 py-3.5 bg-white border border-navy-200/80 rounded-xl text-navy-900 text-sm focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:border-gold-500 transition-all shadow-sm"
              />
            </div>
            
            <!-- Date Field -->
            <div>
              <label for="fecha" class="block text-xs font-bold uppercase tracking-wider text-navy-400 mb-2 font-brand">Fecha de Ingreso</label>
              <input 
                type="date" 
                name="fecha" 
                id="fecha" 
                required 
                class="w-full px-4 py-3.5 bg-white border border-navy-200/80 rounded-xl text-navy-900 text-sm focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:border-gold-500 transition-all shadow-sm"
              />
            </div>
          </div>
          
          <!-- Room Type Field -->
          <div>
            <label for="habitacion" class="block text-xs font-bold uppercase tracking-wider text-navy-400 mb-2 font-brand">Tipo de Habitación</label>
            <select 
              name="habitacion" 
              id="habitacion" 
              required
              class="w-full px-4 py-3.5 bg-white border border-navy-200/80 rounded-xl text-navy-900 text-sm focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:border-gold-500 transition-all appearance-none cursor-pointer shadow-sm"
            >
              <option value="" disabled selected>Selecciona una opción</option>
              <option value="suite-matrimonial">Suite Matrimonial - 100 BOB</option>
              <option value="suite-doble">Suite Doble (Dos Camas) - 140 BOB</option>
              <option value="simple">Habitación Simple - Desde 50 BOB</option>
            </select>
          </div>
          
          <!-- Comments Field -->
          <div>
            <label for="comentarios" class="block text-xs font-bold uppercase tracking-wider text-navy-400 mb-2 font-brand">Comentarios o indicaciones adicionales</label>
            <textarea 
              name="comentarios" 
              id="comentarios" 
              rows="4" 
              placeholder="Ej. Hora aproximada de llegada, requerimientos especiales, etc." 
              class="w-full px-4 py-3.5 bg-white border border-navy-200/80 rounded-xl text-navy-900 text-sm focus:outline-none focus:ring-2 focus:ring-gold-500/50 focus:border-gold-500 transition-all resize-none shadow-sm"
            ></textarea>
          </div>
          
          <!-- Submit Button -->
          <button 
            type="submit" 
            class="shimmer-btn w-full inline-flex items-center justify-center px-6 py-4 border border-transparent text-sm font-bold rounded-xl text-white bg-gradient-to-r from-navy-900 to-navy-800 hover:from-navy-800 hover:to-navy-700 active:scale-95 hover:scale-[1.01] transition-all duration-150 shadow-lg shadow-navy-900/30"
          >
            Enviar Solicitud de Reserva
          </button>
        </form>
      </div>
      
    </div>
  </div>
</section>
