---
// Location Component
---

<section id="ubicacion" class="py-20 bg-gradient-to-b from-navy-900 to-navy-950 text-white relative overflow-hidden">
  <!-- Decorative Background elements -->
  <div class="absolute inset-0 opacity-15">
    <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full bg-gold-600/10 blur-3xl"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">
        Ubicación Estratégica
      </h2>
      <div class="h-1.5 w-20 bg-gold-500 mx-auto mt-4 rounded-full"></div>
      <p class="mt-5 text-lg text-navy-200">
        Estamos ubicados a pasos de la Terminal Bimodal (Metropolitana) de El Alto. La ubicación perfecta para descansar apenas llegues o antes de viajar.
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Text details & Directions -->
      <div class="lg:col-span-5 space-y-8">
        
        <!-- Address card -->
        <div class="bg-navy-800/40 border border-navy-700/60 p-6 rounded-2xl">
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-gold-500/10 flex items-center justify-center text-gold-400 text-lg font-bold">
              📍
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">Dirección de Referencia</h3>
              <p class="text-navy-200 text-sm mt-1 leading-relaxed">
                Avenida José Ballivián Nro. 3862, Zona Bolívar C, Distrito 3, El Alto, Bolivia.
              </p>
            </div>
          </div>
        </div>

        <!-- Walking directions -->
        <div class="space-y-4">
          <h4 class="text-xs font-bold uppercase tracking-wider text-gold-400 font-brand">¿Cómo llegar caminando?</h4>
          
          <div class="flex items-start space-x-3">
            <div class="w-6 h-6 rounded-full bg-navy-800 border border-navy-700 text-xs font-bold flex items-center justify-center text-gold-400 flex-shrink-0 mt-0.5">
              1
            </div>
            <p class="text-navy-200 text-sm">Sal de la Terminal Metropolitana de El Alto.</p>
          </div>
          
          <div class="flex items-start space-x-3">
            <div class="w-6 h-6 rounded-full bg-navy-800 border border-navy-700 text-xs font-bold flex items-center justify-center text-gold-400 flex-shrink-0 mt-0.5">
              2
            </div>
            <p class="text-navy-200 text-sm">Dirígete hacia la Avenida José Ballivián, en la Zona Bolívar C.</p>
          </div>
          
          <div class="flex items-start space-x-3">
            <div class="w-6 h-6 rounded-full bg-navy-800 border border-navy-700 text-xs font-bold flex items-center justify-center text-gold-400 flex-shrink-0 mt-0.5">
              3
            </div>
            <p class="text-navy-200 text-sm">Ubica el Nro. 3862. Verás nuestro letrero de <strong class="text-gold-300">Hospedaje Lambin Suite</strong>.</p>
          </div>
        </div>

        <!-- Extra travel info -->
        <div class="grid grid-cols-2 gap-4 border-t border-navy-800 pt-6">
          <div>
            <span class="text-xs text-navy-400 block">Aeropuerto El Alto</span>
            <span class="text-sm font-bold text-white">✈ A 10 mins en Taxi</span>
          </div>
          <div>
            <span class="text-xs text-navy-400 block">Centro de La Paz</span>
            <span class="text-sm font-bold text-white">🚡 Teleférico a 15 mins</span>
          </div>
        </div>
        
        <!-- Google Maps Button -->
        <a 
          href="https://maps.app.goo.gl/XcXjaftpU6ANr16d7" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-sm font-bold rounded-xl text-navy-950 bg-gold-500 hover:bg-gold-400 hover:scale-[1.02] shadow-lg shadow-gold-500/10 transition-all duration-150 w-full sm:w-auto"
        >
          🗺 Abrir en Google Maps
        </a>
      </div>
      
      <!-- Interactive Map Frame -->
      <div class="lg:col-span-7">
        <div class="relative w-full aspect-[16/10] sm:aspect-[16/9] lg:aspect-[4/3] rounded-2xl overflow-hidden border border-navy-800 shadow-2xl bg-navy-950">
          <iframe 
            src="https://maps.google.com/maps?q=HOSPEDAJE+LAMBIN+SUITE+El+Alto&z=17&output=embed" 
            class="absolute inset-0 w-full h-full border-0" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa de ubicación de Hospedaje Lambin Suite en El Alto">
          </iframe>
        </div>
      </div>
      
    </div>
  </div>
</section>
