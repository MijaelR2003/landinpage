---
// Location Component
---

<section id="ubicacion" class="py-20 bg-gradient-to-br from-navy-900 via-navy-950 to-navy-900 text-white relative overflow-hidden">
  <!-- Decorative Background elements -->
  <div class="absolute inset-0">
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full bg-gold-600/6 blur-[100px]"></div>
    <div class="absolute top-0 right-0 w-[300px] h-[300px] rounded-full bg-navy-500/10 blur-[80px]"></div>
    <div class="absolute inset-0 bg-dot-pattern opacity-15"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">
        Ubicación Estratégica
      </h2>
      <div class="h-1.5 w-20 bg-gradient-to-r from-gold-600 via-gold-400 to-gold-600 mx-auto mt-4 rounded-full"></div>
      <p class="mt-5 text-lg text-navy-200">
        Estamos ubicados a pasos de la Terminal Bimodal (Metropolitana) de El Alto. La ubicación perfecta para descansar apenas llegues o antes de viajar.
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Text details & Directions -->
      <div class="lg:col-span-5 space-y-8">
        
        <!-- Address card -->
        <div class="glass p-6 rounded-2xl">
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-gold-500/15 flex items-center justify-center text-gold-400 text-lg font-bold">
              📍
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">Dirección de Referencia</h3>
              <p class="text-navy-200 text-sm mt-1 leading-relaxed">
                Avenida José Ballivián Nro. 3862, Zona Bolívar C, Distrito 3, El Alto, Bolivia.
              </p>
            </div>
          </div>
        </div>

        <!-- Walking directions -->
        <div class="space-y-4">
          <h4 class="text-xs font-bold uppercase tracking-wider text-gold-400 font-brand">¿Cómo llegar caminando?</h4>
          
          <div class="flex items-start space-x-3">
            <div class="w-7 h-7 rounded-full bg-gradient-to-br from-gold-500 to-gold-600 text-navy-950 text-xs font-extrabold flex items-center justify-center flex-shrink-0 mt-0.5 shadow-md shadow-gold-500/20">
              1
            </div>
            <p class="text-navy-200 text-sm">Sal de la Terminal Metropolitana de El Alto.</p>
          </div>
          
          <div class="flex items-start space-x-3">
            <div class="w-7 h-7 rounded-full bg-gradient-to-br from-gold-500 to-gold-600 text-navy-950 text-xs font-extrabold flex items-center justify-center flex-shrink-0 mt-0.5 shadow-md shadow-gold-500/20">
              2
            </div>
            <p class="text-navy-200 text-sm">Dirígete hacia la Avenida José Ballivián, en la Zona Bolívar C.</p>
          </div>
          
          <div class="flex items-start space-x-3">
            <div class="w-7 h-7 rounded-full bg-gradient-to-br from-gold-500 to-gold-600 text-navy-950 text-xs font-extrabold flex items-center justify-center flex-shrink-0 mt-0.5 shadow-md shadow-gold-500/20">
              3
            </div>
            <p class="text-navy-200 text-sm">Ubica el Nro. 3862. Verás nuestro letrero de <strong class="text-gold-300">Hospedaje Lambin Suite</strong>.</p>
          </div>
        </div>

        <!-- Extra travel info -->
        <div class="grid grid-cols-2 gap-4 border-t border-gold-500/10 pt-6">
          <div class="glass p-3 rounded-xl text-center">
            <span class="text-xs text-navy-400 block">Aeropuerto El Alto</span>
            <span class="text-sm font-bold text-white">✈ A 10 mins en Taxi</span>
          </div>
          <div class="glass p-3 rounded-xl text-center">
            <span class="text-xs text-navy-400 block">Centro de La Paz</span>
            <span class="text-sm font-bold text-white">🚡 Teleférico a 15 mins</span>
          </div>
        </div>
        
        <!-- Google Maps Button -->
        <a 
          href="https://maps.app.goo.gl/XcXjaftpU6ANr16d7" 
          target="_blank" 
          rel="noopener noreferrer"
          class="shimmer-btn inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-sm font-bold rounded-xl text-navy-950 bg-gradient-to-r from-gold-500 to-gold-400 hover:from-gold-400 hover:to-gold-300 hover:scale-[1.02] shadow-lg shadow-gold-500/20 transition-all duration-150 w-full sm:w-auto"
        >
          🗺 Abrir en Google Maps
        </a>
      </div>
      
      <!-- Interactive Map Frame -->
      <div class="lg:col-span-7">
        <div class="relative w-full aspect-[16/10] sm:aspect-[16/9] lg:aspect-[4/3] rounded-2xl overflow-hidden border border-gold-500/15 shadow-2xl shadow-navy-950/50 bg-navy-950">
          <!-- Gold accent glow around map -->
          <div class="absolute -inset-1 rounded-2xl bg-gradient-to-br from-gold-500/15 via-transparent to-gold-500/15 blur-sm -z-10"></div>
          <iframe 
            src="https://maps.google.com/maps?q=HOSPEDAJE+LAMBIN+SUITE+El+Alto&z=17&output=embed" 
            class="absolute inset-0 w-full h-full border-0" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa de ubicación de Hospedaje Lambin Suite en El Alto">
          </iframe>
        </div>
      </div>
      
    </div>
  </div>
</section>
