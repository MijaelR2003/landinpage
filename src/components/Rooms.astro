---
// Rooms Component

const rooms = [
  {
    id: "suite-matrimonial",
    name: "Suite Matrimonial",
    price: "100 BOB",
    capacity: "2 Personas",
    image: "/images/habitacion_suite.png",
    description: "Habitación suite alfombrada con cama matrimonial de 2 plazas. Ofrece confort y privacidad para parejas.",
    features: ["Cama de 2 plazas", "Piso Alfombrado", "Baño Privado con Ducha", "TV Smart", "Acceso WiFi", "Toallas y amenities"],
    whatsappMessage: "Hola Lambin Suite, me interesa reservar la Suite Matrimonial de 100 BOB."
  },
  {
    id: "suite-doble",
    name: "Suite Doble (Dos Camas)",
    price: "140 BOB",
    capacity: "2 Personas",
    image: "/images/habitacion_doble.png",
    description: "Habitación suite alfombrada con dos camas de plaza y media/Queen. Espacio amplio y comodidad para dos personas.",
    features: ["Dos Camas de plaza/media", "Piso Alfombrado", "Baño Privado con Ducha", "TV Smart", "Acceso WiFi", "Toallas y amenities"],
    whatsappMessage: "Hola Lambin Suite, me interesa reservar la Suite Doble de 140 BOB."
  },
  {
    id: "simple",
    name: "Habitación Simple",
    price: "Desde 50 BOB",
    capacity: "1 Persona",
    image: "/images/habitacion_simple.png",
    description: "Habitación económica y acogedora con cama de 1.5 plazas y baño compartido. Ideal para estancias rápidas y descansos prácticos.",
    features: ["Cama de 1.5 plazas", "Baño Compartido", "TV Smart", "Acceso WiFi", "Toallas y Jabón gratis", "Agua Caliente 24/7"],
    whatsappMessage: "Hola Lambin Suite, me interesa reservar la Habitación Simple desde 50 BOB."
  }
];
---

<section id="habitaciones" class="py-20 bg-gradient-to-b from-navy-50/30 to-white relative">
  <!-- Dot pattern background -->
  <div class="absolute inset-0 bg-dot-pattern opacity-30"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-navy-900 tracking-tight">
        Nuestras Habitaciones y Tarifas
      </h2>
      <div class="h-1.5 w-20 bg-gradient-to-r from-gold-600 via-gold-400 to-gold-600 mx-auto mt-4 rounded-full"></div>
      <p class="mt-5 text-lg text-navy-700/80">
        Precios claros y competitivos. Todas nuestras habitaciones están impecablemente limpias y listas para tu confort inmediato.
      </p>
    </div>
    
    <!-- Rooms Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {rooms.map((room) => (
        <div class="gold-accent-top flex flex-col bg-white rounded-2xl overflow-hidden shadow-lg border border-navy-100/60 hover:shadow-xl hover:shadow-gold-500/8 hover:scale-[1.02] transition-all duration-300 group">
          
          <!-- Image Container with Price Badge -->
          <div class="relative overflow-hidden aspect-[4/3] bg-navy-50">
            <img 
              src={room.image} 
              alt={room.name} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <!-- Subtle gold overlay on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-navy-950/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <!-- Price Badge -->
            <div class="absolute top-4 right-4 glass text-white font-extrabold text-lg px-4 py-2 rounded-xl">
              <span class="text-gold-gradient font-black">{room.price}</span>
              <span class="text-[10px] text-navy-200 font-normal block text-right -mt-1">/ noche</span>
            </div>
            <!-- Capacity Badge -->
            <div class="absolute bottom-4 left-4 glass text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center space-x-1.5">
              <span>👤 {room.capacity}</span>
            </div>
          </div>
          
          <!-- Content Container -->
          <div class="flex flex-col flex-grow p-6 sm:p-8">
            <h3 class="text-xl sm:text-2xl font-bold text-navy-900 mb-3">{room.name}</h3>
            <p class="text-navy-700/80 text-sm leading-relaxed mb-6 flex-grow">{room.description}</p>
            
            <!-- Features List -->
            <div class="border-t border-navy-100 pt-6 mb-8">
              <h4 class="text-xs font-bold uppercase tracking-wider text-navy-400 mb-4 font-brand">¿Qué incluye?</h4>
              <ul class="grid grid-cols-2 gap-y-2.5 gap-x-4 text-xs font-medium text-navy-850">
                {room.features.map((feature) => (
                  <li class="flex items-center space-x-2">
                    <span class="text-gold-500 text-sm font-bold">✓</span>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
            
            <!-- CTA Button -->
            <a 
              href={`https://wa.me/59169954561?text=${encodeURIComponent(room.whatsappMessage)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="shimmer-btn w-full inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-sm font-bold rounded-xl text-navy-950 bg-gradient-to-r from-gold-500 to-gold-400 hover:from-gold-400 hover:to-gold-300 active:scale-95 shadow-md shadow-gold-500/15 hover:shadow-gold-500/30 transition-all duration-150"
            >
              Reservar por WhatsApp
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
